# Получите токен у @BotFather
BOT_TOKEN=1234567890:PASTE_YOUR_TELEGRAM_BOT_TOKEN_HERE

# Необязательно. Оставьте пустым для бесплатного гостевого доступа.
TRACE_MOE_API_KEY=

# Минимальная уверенность совпадения: от 0 до 1
MIN_SIMILARITY=0.65

# Сколько результатов отправлять: от 1 до 5
MAX_RESULTS=3

# Общий тайм-аут запроса к trace.moe
REQUEST_TIMEOUT=35

# Telegram Bot API позволяет боту скачивать файлы до 20 МБ
MAX_IMAGE_SIZE_MB=20

# true — удалить накопившиеся обновления при запуске
DROP_PENDING_UPDATES=false
